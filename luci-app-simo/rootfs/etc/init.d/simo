#!/bin/sh /etc/rc.common

START=21
STOP=79
USE_PROCD=1

SIMO_DIR="/opt/simo"
CORE_BIN="${SIMO_DIR}/bin/core"
SIMO_RULES="${SIMO_DIR}/bin/simo-rules"
KERNEL_MANAGER="${SIMO_DIR}/bin/simo-kernel-manager"
RUNTIME_BIN="${SIMO_DIR}/bin/simo-runtime"
RULESET_TMPFS="/tmp/simo/ruleset"
RULESET_LINK="${SIMO_DIR}/ruleset"
PROXY_PROVIDERS_TMPFS="/tmp/simo/proxy_providers"
PROXY_PROVIDERS_LINK="${SIMO_DIR}/proxy_providers"
DNS_BACKUP_FILE="/tmp/simo/simo_dns_backup"
SETTINGS_FILE="${SIMO_DIR}/settings"
RUNTIME_CORE_FILE="/tmp/simo/runtime_core"
DEFAULT_MIHOMO_CONFIG="${SIMO_DIR}/config.yaml"
DEFAULT_SINGBOX_CONFIG="${SIMO_DIR}/config-singbox.json"
USE_TMPFS_RULES="true"

if [ -f "$SETTINGS_FILE" ]; then
	tmpfs_val="$(grep -m1 '^USE_TMPFS_RULES=' "$SETTINGS_FILE" 2>/dev/null | cut -d'=' -f2)"
	[ "$tmpfs_val" = "false" ] && USE_TMPFS_RULES="false"
fi

# Function to log messages
msg() {
	logger -p daemon.info -st "simo[$$]" "$*"
}

is_active_mihomo() {
	if [ -x "$KERNEL_MANAGER" ]; then
		[ "$("$KERNEL_MANAGER" get-active 2>/dev/null)" = "mihomo" ]
		return $?
	fi

	"$CORE_BIN" -v 2>/dev/null | grep -qi 'mihomo'
}

sync_active_core() {
	[ -x "$KERNEL_MANAGER" ] || return 0
	"$KERNEL_MANAGER" sync >/dev/null 2>&1 || true
}

get_runtime_core() {
	if [ -x "$RUNTIME_BIN" ]; then
		local detected
		detected="$("$RUNTIME_BIN" get-active 2>/dev/null || true)"
		case "$detected" in
			mihomo|sing-box)
				echo "$detected"
				return 0
				;;
		esac
	fi

	if is_active_mihomo; then
		echo "mihomo"
	else
		echo "sing-box"
	fi
}

get_runtime_config_path() {
	local core="$1"
	if [ -x "$RUNTIME_BIN" ]; then
		local path
		path="$("$RUNTIME_BIN" get-config-path "$core" 2>/dev/null || true)"
		[ -n "$path" ] && echo "$path" && return 0
	fi

	case "$core" in
		sing-box) echo "$DEFAULT_SINGBOX_CONFIG" ;;
		*) echo "$DEFAULT_MIHOMO_CONFIG" ;;
	esac
}

set_runtime_state_core() {
	local core="$1"
	mkdir -p /tmp/simo
	printf '%s\n' "$core" > "$RUNTIME_CORE_FILE"
}

read_runtime_state_core() {
	[ -f "$RUNTIME_CORE_FILE" ] || return 1
	sed -n '1p' "$RUNTIME_CORE_FILE" 2>/dev/null
}

clear_runtime_state_core() {
	rm -f "$RUNTIME_CORE_FILE"
}

# Function to check the existence of files/directories
check_files() {
	sync_active_core

	if [ ! -x "$CORE_BIN" ]; then
		msg "ERROR: Active core binary not found at $CORE_BIN"
		return 1
	fi

	if [ ! -f "$SIMO_RULES" ]; then
		msg "WARNING: Rules script not found at $SIMO_RULES"
	fi

	if [ ! -x "$RUNTIME_BIN" ]; then
		msg "ERROR: Runtime adapter not found at $RUNTIME_BIN"
		return 1
	fi

	return 0
}

# Function to set up runtime directories
setup_runtime_directories() {
	if [ "$USE_TMPFS_RULES" = "true" ]; then
		# Setup ruleset in tmpfs with symlink from SIMO_DIR
		if [ ! -d "$RULESET_TMPFS" ]; then
			if ! mkdir -p "$RULESET_TMPFS"; then
				msg "ERROR: Failed to create directory $RULESET_TMPFS"
				return 1
			fi
			msg "Created directory '$RULESET_TMPFS'"
		fi

		if [ ! -L "$RULESET_LINK" ] || [ "$(readlink "$RULESET_LINK")" != "$RULESET_TMPFS" ]; then
			rm -rf "$RULESET_LINK"
			if ! ln -s "$RULESET_TMPFS" "$RULESET_LINK"; then
				msg "ERROR: Failed to create symlink from '$RULESET_TMPFS' to '$RULESET_LINK'"
				return 1
			fi
			msg "Created symlink from '$RULESET_TMPFS' to '$RULESET_LINK'"
		fi

		# Setup proxy_providers in tmpfs with symlink from SIMO_DIR
		if [ ! -d "$PROXY_PROVIDERS_TMPFS" ]; then
			if ! mkdir -p "$PROXY_PROVIDERS_TMPFS"; then
				msg "ERROR: Failed to create directory $PROXY_PROVIDERS_TMPFS"
				return 1
			fi
			msg "Created directory '$PROXY_PROVIDERS_TMPFS'"
		fi

		if [ ! -L "$PROXY_PROVIDERS_LINK" ] || [ "$(readlink "$PROXY_PROVIDERS_LINK")" != "$PROXY_PROVIDERS_TMPFS" ]; then
			rm -rf "$PROXY_PROVIDERS_LINK"
			if ! ln -s "$PROXY_PROVIDERS_TMPFS" "$PROXY_PROVIDERS_LINK"; then
				msg "ERROR: Failed to create symlink from '$PROXY_PROVIDERS_TMPFS' to '$PROXY_PROVIDERS_LINK'"
				return 1
			fi
			msg "Created symlink from '$PROXY_PROVIDERS_TMPFS' to '$PROXY_PROVIDERS_LINK'"
		fi
	else
		# Use persistent storage under SIMO_DIR without tmpfs or symlinks
		if [ -L "$RULESET_LINK" ]; then
			rm -f "$RULESET_LINK"
		fi
		if [ ! -d "$RULESET_LINK" ]; then
			if ! mkdir -p "$RULESET_LINK"; then
				msg "ERROR: Failed to create persistent ruleset directory $RULESET_LINK"
				return 1
			fi
			msg "Created persistent ruleset directory '$RULESET_LINK'"
		fi

		if [ -L "$PROXY_PROVIDERS_LINK" ]; then
			rm -f "$PROXY_PROVIDERS_LINK"
		fi
		if [ ! -d "$PROXY_PROVIDERS_LINK" ]; then
			if ! mkdir -p "$PROXY_PROVIDERS_LINK"; then
				msg "ERROR: Failed to create persistent proxy_providers directory $PROXY_PROVIDERS_LINK"
				return 1
			fi
			msg "Created persistent proxy_providers directory '$PROXY_PROVIDERS_LINK'"
		fi
	fi

	return 0
}

# Function to configure DNS
setup_dns() {
	local dns_server="127.0.0.1#7874"

	# Save original cachesize and noresolv values so restore_dns can put them back
	# exactly as they were, rather than simply deleting them (which would lose any
	# value the admin had explicitly configured before the proxy was started).
	local orig_cachesize
	local orig_noresolv
	orig_cachesize=$(uci get dhcp.@dnsmasq[0].cachesize 2>/dev/null)
	orig_noresolv=$(uci get dhcp.@dnsmasq[0].noresolv 2>/dev/null)
	printf 'CACHESIZE=%s\nNORESOLV=%s\n' "$orig_cachesize" "$orig_noresolv" > "$DNS_BACKUP_FILE"

	# Check if the server is already added
	local existing_server
	existing_server=$(uci get dhcp.@dnsmasq[0].server 2>/dev/null | grep "$dns_server")

	if [ -z "$existing_server" ]; then
		uci add_list dhcp.@dnsmasq[0].server="$dns_server" || {
			msg "ERROR: Failed to add DNS server"
			return 1
		}
	fi

	uci set dhcp.@dnsmasq[0].cachesize='0' || {
		msg "ERROR: Failed to set cachesize"
		return 1
	}

	uci set dhcp.@dnsmasq[0].noresolv='1' || {
		msg "ERROR: Failed to set noresolv"
		return 1
	}

	if ! uci commit dhcp; then
		msg "ERROR: Failed to commit DNS changes"
		return 1
	fi

	msg "DNS settings configured"
	return 0
}

# Function to restore DNS settings
restore_dns() {
	local dns_server="127.0.0.1#7874"

	# Get the list of servers and remove only ours
	local servers
	servers=$(uci get dhcp.@dnsmasq[0].server 2>/dev/null)
	if echo "$servers" | grep -q "$dns_server"; then
		uci del_list dhcp.@dnsmasq[0].server="$dns_server" 2>/dev/null
	fi

	# Restore the exact original values we saved before modifying them.
	# If no backup file exists (e.g. service stopped without having been fully
	# started), keep cachesize/noresolv untouched.
	local orig_cachesize=""
	local orig_noresolv=""
	if [ ! -f "$DNS_BACKUP_FILE" ]; then
		if uci commit dhcp; then
			msg "DNS server entry cleaned (no backup state present)"
		else
			msg "WARNING: Failed to commit DNS cleanup (no backup state present)"
		fi
		return 0
	fi

	orig_cachesize=$(grep '^CACHESIZE=' "$DNS_BACKUP_FILE" | cut -d= -f2)
	orig_noresolv=$(grep '^NORESOLV=' "$DNS_BACKUP_FILE" | cut -d= -f2)
	rm -f "$DNS_BACKUP_FILE"

	if [ -n "$orig_cachesize" ]; then
		uci set dhcp.@dnsmasq[0].cachesize="$orig_cachesize" 2>/dev/null
	else
		uci delete dhcp.@dnsmasq[0].cachesize 2>/dev/null
	fi

	if [ -n "$orig_noresolv" ]; then
		uci set dhcp.@dnsmasq[0].noresolv="$orig_noresolv" 2>/dev/null
	else
		uci delete dhcp.@dnsmasq[0].noresolv 2>/dev/null
	fi

	if uci commit dhcp; then
		msg "DNS settings restored"
	else
		msg "WARNING: Failed to restore DNS settings"
	fi
}

# Function to apply firewall rules
apply_firewall_rules() {
	if [ -f "$SIMO_RULES" ]; then
		if "$SIMO_RULES" start; then
			msg "Firewall rules applied"
			return 0
		else
			msg "ERROR: Failed to apply firewall rules"
			return 1
		fi
	else
		msg "WARNING: Simo rules script not found, skipping firewall configuration"
		return 0
	fi
}

# Function to remove firewall rules
remove_firewall_rules() {
	if [ -f "$SIMO_RULES" ]; then
		if "$SIMO_RULES" stop; then
			msg "Firewall rules removed"
		else
			msg "WARNING: Failed to remove firewall rules"
		fi
	fi
}

# Function to restart dnsmasq
restart_dnsmasq() {
	if /etc/init.d/dnsmasq restart >/dev/null 2>&1; then
		msg "dnsmasq restarted successfully"
		return 0
	else
		msg "ERROR: Failed to restart dnsmasq"
		return 1
	fi
}

start_service() {
	msg "Starting Simo service..."
	local runtime_core
	local runtime_config

	# Check the required files
	check_files || return 1

	# Set up the directories (ruleset and proxy_providers)
	setup_runtime_directories || return 1

	runtime_core="$(get_runtime_core)"
	runtime_config="$(get_runtime_config_path "$runtime_core")"

	# Generate runtime-specific config before validation/start.
	if ! "$RUNTIME_BIN" prepare "$runtime_core"; then
		msg "ERROR: Failed to prepare runtime configuration for $runtime_core"
		return 1
	fi

	# Check active core configuration through runtime adapter.
	if ! "$RUNTIME_BIN" validate "$runtime_core"; then
		msg "ERROR: Core configuration test failed"
		return 1
	fi

	if [ "$runtime_core" = "mihomo" ]; then
		# Apply firewall rules - failure is fatal: without redirect rules traffic
		# bypasses the proxy entirely, which makes DNS proxying setup incoherent.
		apply_firewall_rules || {
			msg "ERROR: Failed to apply firewall rules, aborting start"
			return 1
		}

		# Set up DNS - on failure, roll back the firewall rules we just applied.
		setup_dns || {
			msg "ERROR: Failed to configure DNS, rolling back firewall rules"
			remove_firewall_rules
			return 1
		}

		# Restart dnsmasq to apply the new DNS settings - on failure, restore DNS
		# config and roll back firewall rules so the system is left consistent.
		restart_dnsmasq || {
			msg "ERROR: Failed to restart dnsmasq, rolling back DNS and firewall rules"
			restore_dns
			/etc/init.d/dnsmasq restart >/dev/null 2>&1 || true
			remove_firewall_rules
			return 1
		}
	else
		msg "Runtime '$runtime_core': skip mihomo-specific firewall and DNS setup"
	fi

	set_runtime_state_core "$runtime_core"

	# Start active core via procd
	procd_open_instance
	procd_set_param command "$RUNTIME_BIN" run "$runtime_core"
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param respawn ${respawn_threshold:-3600} ${respawn_timeout:-5} ${respawn_retry:-5}
	procd_set_param file "$SETTINGS_FILE" "$DEFAULT_MIHOMO_CONFIG" "$DEFAULT_SINGBOX_CONFIG" "$runtime_config"
	procd_close_instance

	msg "Simo service started successfully"
}

stop_service() {
	msg "Stopping Simo service..."
	local runtime_core

	runtime_core="$(read_runtime_state_core || true)"
	[ -n "$runtime_core" ] || runtime_core="$(get_runtime_core)"

	if [ "$runtime_core" = "mihomo" ]; then
		# Remove firewall rules
		remove_firewall_rules

		# Restore DNS settings
		restore_dns

		# Restart dnsmasq
		restart_dnsmasq || {
			msg "WARNING: Failed to restart dnsmasq during stop"
		}
	else
		msg "Runtime '$runtime_core': skip mihomo-specific firewall and DNS cleanup"
	fi

	clear_runtime_state_core

	msg "Simo service stopped"
}
reload_service() {
	msg "Reloading Simo service..."

	stop
	start

	msg "Simo service reloaded"
}

# Called by package manager during removal (`/etc/init.d/simo delete`).
# Make it idempotent: service may already be gone, so ignore "Not found".
delete() {
	ubus call service delete '{ "name": "simo" }' >/dev/null 2>&1 || true
	return 0
}

service_started() {
	# Called by procd every time the service process (re)starts, including respawns.
	# The package-installed /etc/hotplug.d/net/99-simo-tun handles the normal
	# case: when mihomo creates simo-tun, the kernel event fires the hotplug script
	# which calls `simo-rules tun_route_setup`.
	# tun_route_watch covers the fast-respawn edge case where simo-tun is still up
	# when procd fires this callback (interface did not disappear between respawns).
	is_active_mihomo || return 0

	local proxy_mode=""
	[ -f "$SETTINGS_FILE" ] && proxy_mode=$(grep '^PROXY_MODE=' "$SETTINGS_FILE" | cut -d= -f2 | tr -d '[:space:]')
	case "$proxy_mode" in
		mixed|tun)
			if [ -f "$SIMO_RULES" ]; then
				"$SIMO_RULES" tun_route_watch
				local i=0
				while [ "$i" -lt 30 ]; do
					[ -d /sys/class/net/simo-tun ] && break
					sleep 1
					i=$((i + 1))
				done
				"$SIMO_RULES" tun_route_setup
				"$SIMO_RULES" repair_policy
				"$SIMO_RULES" repair_forward_rules
			fi
			;;
	esac
}

service_triggers() {
	procd_add_reload_trigger "simo"
}

boot() {
	# Wait for system initialization
	sleep 10
	start
}
